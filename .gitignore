# ---------------------------------------------------------------------
# Sequence — .gitignore (Swift / SwiftUI / Xcode iOS project)
# ---------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Xcode — user-specific
xcuserdata/
*.xcuserstate
*.xcuserdatad/
*.xcscmblueprint
*.xccheckout

# Xcode project — generated by XcodeGen from project.yml (source of truth)
*.xcodeproj

# Xcode — build products & derived data
build/
DerivedData/
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
*.hmap
*.ipa
*.dSYM.zip
*.dSYM

# Swift Package Manager
.build/
.swiftpm/
Packages/
Package.pins
Package.resolved
*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/

# CocoaPods (in case it's ever added)
Pods/

# Carthage (in case it's ever added)
Carthage/Build/

# Fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Provisioning / signing — never commit
*.mobileprovision
*.p12
*.cer

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# Injection / misc tooling
iOSInjectionProject/

# Logs / temp
*.log
*.tmp

.DS_Store
